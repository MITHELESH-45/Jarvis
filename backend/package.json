{
  "name": "backend",
  "version": "1.0.0",
  "description": "AI Personal Assistant / Digital Twin Backend Database Layer",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node src/index.js",
    "dev:mcp": "node src/mcp-server/server.js",
    "dev:all": "concurrently --names \"APP,MCP\" --prefix-colors \"cyan,magenta\" \"npm run dev\" \"npm run dev:mcp\"",
    "get-token": "node scripts/get-refresh-token.js",
    "rag:ingest": "node src/rag/ingest.js",
    "rag:ingest:reindex": "node src/rag/ingest.js --reindex",
    "rag:ingest:dir": "node src/rag/ingest.js --dir",
    "build": "node -e \"console.log('Backend build complete')\""
  },
  "engines": {
    "node": ">=20 <23",
    "npm": ">=10"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@langchain/community": "^1.1.29",
    "@langchain/core": "^1.2.1",
    "@langchain/google-genai": "^2.2.0",
    "@langchain/openai": "^1.5.3",
    "@langchain/textsplitters": "^1.0.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@pinecone-database/pinecone": "^8.0.0",
    "@prisma/client": "^6.19.3",
    "@types/node": "^26.1.0",
    "concurrently": "^10.0.3",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "google-auth-library": "^10.9.0",
    "googleapis": "^173.0.0",
    "jsonwebtoken": "^9.0.3",
    "pdf-parse": "^2.4.5",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
